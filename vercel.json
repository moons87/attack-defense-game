{
  "env": [
    {
      "key": "NEXT_PUBLIC_FIREBASE_API_KEY",
      "description": "Firebase API Key from Console"
    },
    {
      "key": "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN",
      "description": "Firebase Auth Domain (your-project.firebaseapp.com)"
    },
    {
      "key": "NEXT_PUBLIC_FIREBASE_DATABASE_URL",
      "description": "Firebase Realtime Database URL (https://your-project.firebaseio.com)"
    },
    {
      "key": "NEXT_PUBLIC_FIREBASE_PROJECT_ID",
      "description": "Firebase Project ID"
    }
  ]
}
